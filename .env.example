# Gemini
GEMINI_API_KEY=your_gemini_api_key
GEMINI_CHAT_MODEL=gemini-2.5-flash
GEMINI_FALLBACK_MODEL=gemini-2.5-flash-lite
GEMINI_FALLBACK_MODEL_2=gemini-2.5-pro

# Supabase
SUPABASE_URL=postgresql://postgres:[YOUR_PASSWORD]@db.<project-ref>.supabase.co:5432/postgres
SUPABASE_API_KEY=your_supabase_service_or_secure_api_key

# Embeddings
EMBEDDING_MODEL=gemini-embedding-001

# Runtime paths
LEAD_CAPTURE_PATH=data/marketing_leads.jsonl
ANALYTICS_LOG_PATH=data/chat_analytics.jsonl

# Frontend (set in frontend/.env.local for local dev)
# VITE_API_BASE_URL=http://localhost:8000
